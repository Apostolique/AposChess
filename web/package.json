{
  "name": "aposchess",
  "version": "1.0.0",
  "description": "A playable web UI for the AposChess variant",
  "license": "GPL-3.0-or-later",
  "author": "Jean-David Moisan",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "match": "node scripts/selfplay.mjs",
    "rank": "node scripts/rank-engines.mjs",
    "train": "node scripts/train-pipeline.mjs",
    "train:gen": "node scripts/gen-selfplay.mjs",
    "train:fit": "node scripts/train-fit.mjs",
    "train:featurize": "node scripts/featurize.mjs",
    "train:loop": "node scripts/train-loop.mjs",
    "train:merge": "node --max-old-space-size=8192 scripts/merge-data.mjs",
    "puzzles:mine": "node scripts/mine-puzzles.mjs",
    "parity": "node scripts/engine-parity.mjs",
    "openings:mine": "node --max-old-space-size=8192 scripts/mine-openings.mjs"
  },
  "dependencies": {
    "@lichess-org/chessground": "^10.1.1",
    "trystero": "^0.25.1"
  },
  "devDependencies": {
    "vite": "^6.0.0"
  }
}
